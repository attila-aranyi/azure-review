# ──────────────────────────────────────────────────────────
# AI Code Review — Self-Hosted Configuration
# Copy this file to .env and fill in the values.
# Run ./setup.sh for interactive first-time setup.
# ──────────────────────────────────────────────────────────

# ── Azure DevOps Connection ──────────────────────────────
# Your Azure DevOps organization URL (e.g., https://dev.azure.com/myorg)
ADO_ORG=

# Personal Access Token with Code (Read & Write) scope
ADO_PAT=

# Project to enable reviews for
ADO_PROJECT=

# Webhook secret (auto-generated by setup.sh)
WEBHOOK_SECRET=

# ── LLM Provider (at least one required) ─────────────────
# Anthropic (recommended)
ANTHROPIC_API_KEY=

# OpenAI (alternative)
OPENAI_API_KEY=

# Azure OpenAI (alternative)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# ── LLM Stage Configuration ─────────────────────────────
# Providers: mock | openai | azure_openai | anthropic
LLM1_PROVIDER=anthropic
LLM2_PROVIDER=anthropic

# Model overrides (defaults to provider's best model)
ANTHROPIC_MODEL_LLM1=
ANTHROPIC_MODEL_LLM2=
OPENAI_MODEL_LLM1=
OPENAI_MODEL_LLM2=

# ── Optional: Accessibility Checker (LLM3) ──────────────
LLM3_ENABLED=false
LLM3_PROVIDER=anthropic
A11Y_FILE_EXTENSIONS=.html,.jsx,.tsx,.vue,.svelte,.css,.scss

# ── Database (bundled by default) ────────────────────────
# To use an external database, set the full connection URL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
POSTGRES_USER=llmreview
POSTGRES_PASSWORD=
POSTGRES_DB=llmreview
POSTGRES_PORT=5432

# ── Redis (optional, enables async processing) ──────────
# To use an external Redis, set the full URL:
# REDIS_URL=redis://host:6379
# To enable bundled Redis, run: docker compose --profile redis up -d
REDIS_PORT=6379

# ── Axon Code Intelligence (optional) ───────────────────
# Set to true and run: docker compose --profile axon up -d
AXON_ENABLED=false

# ── Server ───────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info
CORS_ORIGINS=

# ── Review Limits ────────────────────────────────────────
MAX_FILES=20
MAX_TOTAL_DIFF_LINES=2000
MAX_HUNKS=80
HUNK_CONTEXT_LINES=20
TOKEN_BUDGET_LLM1=3000
TOKEN_BUDGET_LLM2=6000

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000
