# ── Server ─────────────────────────────────────────────────────────
PORT=3000
WEBHOOK_SECRET=<generate-a-random-secret>

# ── Azure DevOps ───────────────────────────────────────────────────
ADO_ORG=<your-azure-devops-org>
ADO_PROJECT=code-review-test
ADO_PAT=<your-azure-devops-pat>

# ── LLM Providers (Anthropic) ─────────────────────────────────────
LLM1_PROVIDER=anthropic
LLM2_PROVIDER=anthropic
ANTHROPIC_API_KEY=<your-anthropic-api-key>
ANTHROPIC_MODEL_LLM1=claude-sonnet-4-6
ANTHROPIC_MODEL_LLM2=claude-sonnet-4-6

# ── LLM3: Accessibility checker (optional) ────────────────────────
LLM3_ENABLED=false
LLM3_PROVIDER=anthropic
ANTHROPIC_MODEL_LLM3=claude-sonnet-4-6
TOKEN_BUDGET_LLM3=4000
A11Y_FILE_EXTENSIONS=.html,.jsx,.tsx,.vue,.svelte,.css,.scss

# ── Limits ─────────────────────────────────────────────────────────
MAX_FILES=20
MAX_TOTAL_DIFF_LINES=2000
MAX_HUNKS=80
HUNK_CONTEXT_LINES=20
TOKEN_BUDGET_LLM1=3000
TOKEN_BUDGET_LLM2=6000

# ── CORS ───────────────────────────────────────────────────────────
CORS_ORIGINS=

# ── Rate Limiting ──────────────────────────────────────────────────
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# ── Redis (leave empty for synchronous mode) ───────────────────────
REDIS_URL=
