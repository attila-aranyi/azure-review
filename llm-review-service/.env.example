PORT=3000
WEBHOOK_SECRET=replace-me

# Azure DevOps
ADO_ORG=myorg
ADO_PROJECT=myproject
ADO_PAT=replace-me

# LLM stage providers: mock|openai|azure_openai|anthropic
LLM1_PROVIDER=mock
LLM2_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL_LLM1=
OPENAI_MODEL_LLM2=

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_LLM1=
AZURE_OPENAI_DEPLOYMENT_LLM2=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_LLM1=
ANTHROPIC_MODEL_LLM2=

# LLM3: Accessibility checker (optional, disabled by default)
LLM3_ENABLED=false
LLM3_PROVIDER=mock
OPENAI_MODEL_LLM3=
AZURE_OPENAI_DEPLOYMENT_LLM3=
ANTHROPIC_MODEL_LLM3=
TOKEN_BUDGET_LLM3=4000
A11Y_FILE_EXTENSIONS=.html,.jsx,.tsx,.vue,.svelte,.css,.scss

# Limits
MAX_FILES=20
MAX_TOTAL_DIFF_LINES=2000
MAX_HUNKS=80
HUNK_CONTEXT_LINES=20
TOKEN_BUDGET_LLM1=3000
TOKEN_BUDGET_LLM2=6000

# CORS — comma-separated origins (empty = deny all cross-origin)
CORS_ORIGINS=

# Rate limiting — per-IP limits on webhook endpoint
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# Optional Redis queue (enables async processing)
REDIS_URL=
